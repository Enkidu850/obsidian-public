{
  "name": "obsidian",
  "displayName": "Obsidian",
  "description": "Langage de programmation créé par Romain MONJARET",
  "publisher": "Romain-MONJARET",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.98.0"
  },
  "icon": "obs-icon.png",
  "icons": {
    "file": {
      "icon": "obs-icon.png"
    }
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "obs",
        "aliases": [
          "Obsidian",
          "obs"
        ],
        "extensions": [
          ".obs"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "obs-icon.png",
          "dark": "obs-icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "obs",
        "scopeName": "source.obs",
        "path": "./syntaxes/obs.tmLanguage.json"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NathanLapaille/obsidian.git"
  },
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "sync-public": "powershell -NoProfile -Command \"Copy-Item '../obsidian/*' -Destination '../TEST_PUBLIC/obsidian/' -Recurse -Force -Exclude @('node_modules', '.git', '.vscode', '*.vsix')\"",
    "sync-and-push": "npm run sync-public && cd ../TEST_PUBLIC/obsidian && git add . && git commit -m \"Sync from private\" && git push --force && cd ../../.."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/NathanLapaille/obsidian/issues"
  },
  "homepage": "https://github.com/NathanLapaille/obsidian#readme",
  "devDependencies": {
    "@vscode/vsce": "^3.7.1"
  }
}
